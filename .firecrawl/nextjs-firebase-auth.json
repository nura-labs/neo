      const newRatingDocument = doc(
        collection(db, `restaurants/${restaurantId}/ratings`),
      );
  
      // corrected line
      await runTransaction(db, (transaction) =>
        updateWithRating(transaction, docRef, newRatingDocument, review),
      );
    } catch (error) {
      console.error(
